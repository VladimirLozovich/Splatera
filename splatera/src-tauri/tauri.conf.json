{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "splatera",
  "version": "0.1.0",
  "identifier": "com.splatera.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "splatera",
        "width": 345,
        "height": 875,
        "minHeight": 200,
        "minWidth": 345,
        "dragDropEnabled": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
      "enable": true,
      "scope": ["**"] 
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
